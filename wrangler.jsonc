{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "collagejs",
  "main": ".svelte-kit/cloudflare/_worker.js",
  "compatibility_flags": [
    "nodejs_als"
  ],
  "compatibility_date": "2026-07-14",
  "route": "*.collagejs.dev/*",
  "assets": {
    "binding": "ASSETS",
    "directory": ".svelte-kit/cloudflare"
  },
  "observability": {
    "logs": {
      "enabled": false,
      "invocation_logs": true
    }
  }
}